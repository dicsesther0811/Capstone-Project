            {tab === "login" && (
              <label style={{ display:"flex", alignItems:"center", gap:8, fontSize:13, color:"#5a7a56", cursor:"pointer", marginBottom:4 }}>
                <input type="checkbox" checked={remember} onChange={e => setRemember(e.target.checked)} style={{ width:15, height:15, accentColor:"#3a6b34" }} />
