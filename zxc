                              <span className="nut-label">{n.label}</span>
                              <div className="nut-track"><div className="nut-fill" style={{ width:Math.min(100,(n.val/n.max)*100)+"%", background:n.color }} /></div>
                              <span className="nut-val">{n.val}{n.unit}</span>
                            </div>
                          ))
                        ) : <div style={{ textAlign:"center", color:"#aaa", fontSize:13, padding:"16px 0" }}>아직 데이터가 없어요. 식사를 기록해보세요!</div>}
