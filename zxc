                      const wMeals = meals.filter(m => { const d = new Date(m.date); return d >= weekStart && d < weekEnd; });
                      return { name: (4-i) + "주 전", kcal: Math.round(wMeals.reduce((s,m) => s+m.kcal,0) / 7) };
