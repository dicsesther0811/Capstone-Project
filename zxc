              </label>
            )}
            {error && <div className="error-msg">⚠ {error}</div>}
            <button className="btn btn-primary btn-block" style={{ marginTop: 16 }} onClick={tab === "login" ? login : signup}>{tab === "login" ? "로그인" : "회원가입하기"}</button>
            <div className="divider">또는</div>
            <div style={{ fontSize: 12, color: "#9ab096", textAlign: "center" }}>
              {tab === "login" ? "계정이 없으신가요? " : "이미 계정이 있으신가요? "}
              <span style={{ color: "#3a6b34", fontWeight: 600, cursor: "pointer" }} onClick={() => { setTab(tab === "login" ? "signup" : "login"); setError(""); }}>{tab === "login" ? "회원가입" : "로그인"}</span>
            </div>
          </div>
        </div>
      );
    }

