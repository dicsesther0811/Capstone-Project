            </div>
            <div className="modal-body">
              {step === "input" && (
                <>
                  <div className="form-group">
                    <label className="form-label">무엇을 드셨나요? *</label>
                    <textarea className="form-input" placeholder={"예: 된장찌개 한 그릇이랑 밥\n예: 편의점 삼각김밥 2개랑 컵라면"} value={foodText} onChange={e => setFoodText(e.target.value)} rows={3} style={{ resize: "none", lineHeight: 1.6 }} />
                    <div style={{ fontSize: 11, color: "#9ab096", marginTop: 5 }}>자연스럽게 적어주세요. AI가 칼로리를 추정해드려요.</div>
                  </div>
                  <div className="form-group">
                    <label className="form-label">식사 시간</label>
                    <input className="form-input" type="time" value={time} onChange={e => setTime(e.target.value)} />
                  </div>
                  {error && <div className="error-msg">⚠ {error}</div>}
                </>
              )}
              {step === "estimating" && (
                <div style={{ textAlign: "center", padding: "32px 0" }}>
                  <div className="spinner" style={{ margin: "0 auto 16px" }} />
                  <div style={{ fontSize: 14, color: "#5a7a56", marginBottom: 6 }}>AI가 영양 정보를 추정하고 있어요</div>
