                    {favs.length === 0
                      ? <div style={{ textAlign:"center", padding:"28px 0", color:"#aaa" }}>
                          <div style={{ fontSize:32, marginBottom:10 }}>★</div>
                          <div style={{ fontSize:13 }}>즐겨찾기한 음식이 없어요</div>
                          <div style={{ fontSize:12, marginTop:6, color:"#bbb" }}>식사 기록의 ★ 버튼을 눌러 추가하세요</div>
                        </div>
                      : favs.map((f, i) => (
                        <div key={i} className="fav-card">
                          <div style={{ width:40, height:40, borderRadius:10, background:"#eef5ec", display:"flex", alignItems:"center", justifyContent:"center", fontSize:20, flexShrink:0 }}>{f.emoji}</div>
                          <div style={{ flex:1 }}>
                            <div style={{ fontWeight:600, fontSize:14 }}>{f.name}</div>
                            <div style={{ fontSize:11, color:"#888", marginTop:2 }}>{f.kcal}kcal · 단백질 {f.protein}g</div>
                          </div>
                          <div style={{ display:"flex", gap:6 }}>
                            <button className="btn btn-primary btn-sm" style={{ padding:"6px 12px", fontSize:12 }} onClick={() => addFavMeal(f)}>+ 추가</button>
                            <button className="fav-btn active" onClick={() => toggleFav(f)}>★</button>
                          </div>
                        </div>
                      ))
                    }
                  </div>
                  <div style={{ padding:"0 20px 20px" }}>
                    <button className="btn btn-outline btn-block btn-sm" onClick={() => setShowFavs(false)}>닫기</button>
                  </div>
                </div>
              </div>
            )}

            <button className="fab" onClick={() => setShowAdd(true)}>+</button>

            <nav className="bottom-nav">
              {[
                { id:"dash", icon:"📊", label:"홈" },
                { id:"analyze", icon:"📷", label:"분석" },
                { id:"log", icon:"📋", label:"기록" },
                { id:"report", icon:"📈", label:"리포트" },
                { id:"rec", icon:"💡", label:"추천" },
              ].map(n => (
                <div key={n.id} className={`nav-item ${view === n.id ? "active" : ""}`} onClick={() => setView(n.id)}>
                  <div className="nav-icon">{n.icon}</div>
                  <div>{n.label}</div>
                </div>
              ))}
            </nav>
          </div>
        </>
      );
    }

    const root = ReactDOM.createRoot(document.getElementById('root'));
    root.render(<App />);
