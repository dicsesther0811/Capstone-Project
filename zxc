                    <div style={{ flex:1 }}><div className="modal-name">즐겨찾기</div><div className="modal-email">자주 먹는 음식을 빠르게 등록해요</div></div>
                    <button onClick={() => setShowFavs(false)} style={{ background:"none", border:"none", cursor:"pointer", color:"#8aad86", fontSize:22 }}>×</button>
