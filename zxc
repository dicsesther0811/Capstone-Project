                    return diff <= days;
                  });
                  const avg = days > 0 ? Math.round(periodMeals.reduce((s,m) => s+m.kcal,0) / days) : 0;
                  const avgProtein = days > 0 ? Math.round(periodMeals.reduce((s,m) => s+m.protein,0) / days) : 0;
