    /* ─── AUTH SCREEN ─── */
    function AuthScreen({ onLogin, onSignup }) {
      const [tab, setTab] = useState("login");
      const [email, setEmail] = useState("");
      const [pw, setPw] = useState("");
      const [pw2, setPw2] = useState("");
      const [error, setError] = useState("");
      const [remember, setRemember] = useState(true);

      const login = () => {
        const users = getUsers();
        const user = Object.values(users).find(u => u.email === email);
        if (!user) return setError("이메일이 존재하지 않아요.");
        if (user.password !== pw) return setError("비밀번호가 틀렸어요.");
        setError(""); onLogin(user, remember);
      };
      const signup = () => {
        if (!email || !pw) return setError("이메일과 비밀번호를 입력해주세요.");
        if (pw !== pw2) return setError("비밀번호가 일치하지 않아요.");
        if (pw.length < 6) return setError("비밀번호는 6자 이상이어야 해요.");
        const users = getUsers();
        if (Object.values(users).find(u => u.email === email)) return setError("이미 사용 중인 이메일이에요.");
        const uid = "u_" + Date.now();
        const newUser = { uid, email, password: pw, profile: null };
        users[uid] = newUser; saveUsers(users);
        setError(""); onSignup(newUser);
      };

      return (
        <div className="auth-wrap">
          <div className="auth-card">
            <div className="auth-logo">Food<span>Lens</span></div>
            <div className="auth-sub">AI 기반 음식 분석 · 개인 맞춤 식단 추천</div>
