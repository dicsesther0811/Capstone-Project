                  <div className="user-av">{initials}</div>
                  <span className="user-name">{pf.name}</span>
                </button>
                <button className="logout-btn" onClick={logout}>
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2.5" strokeLinecap="round" strokeLinejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
                  로그아웃
                </button>
              </div>
            </header>

            <main className="content">
              {/* ── DASHBOARD ── */}
              <div className={`page ${view === "dash" ? "active" : ""}`}>
                <div className="hero">
                  <div className="hero-greeting">{new Date().toLocaleDateString("ko-KR", { month:"long", day:"numeric", weekday:"long" })}</div>
                  <div className="hero-title">오늘 권장량의 {kcalPct}% 섭취했어요</div>
                  <div className="hero-stats">
                    <div><div className="hero-num">{totals.kcal}</div><div className="hero-lbl">현재 (kcal)</div></div>
                    <div style={{ width: 1, background: "rgba(255,255,255,0.15)" }} />
                    <div><div className="hero-num">{targetKcal}</div><div className="hero-lbl">목표 (kcal)</div></div>
                    <div style={{ width: 1, background: "rgba(255,255,255,0.15)" }} />
                    <div><div className="hero-num">{todayMeals.length}끼</div><div className="hero-lbl">식사 기록</div></div>
                  </div>
                </div>

                <div className="card">
                  <div style={{ display:"flex", justifyContent:"space-between", alignItems:"center", marginBottom:10 }}>
                    <div>
                      <div style={{ fontWeight:700, fontSize:14 }}>💧 수분 섭취</div>
                      <div style={{ fontSize:12, color:"#888", marginTop:2 }}>오늘 {water * 250}ml / 권장 2,000ml</div>
                    </div>
                    <div style={{ fontSize:12, fontWeight:700, color: water >= 8 ? "#3a6b34" : water >= 5 ? "#8a6a00" : "#c0402a" }}>
                      {water >= 8 ? "✅ 달성!" : water >= 5 ? "절반 이상" : "부족해요"}
                    </div>
                  </div>
                  <div style={{ display:"flex", gap:6, alignItems:"center" }}>
                    {[...Array(8)].map((_, i) => (
                      <button key={i} className={"water-btn" + (i < water ? " filled" : "")}
                        onClick={() => setWater(i < water ? i : i + 1)}>
                        {i < water ? "💧" : "○"}
                      </button>
                    ))}
                  </div>
                  <div style={{ display:"flex", justifyContent:"space-between", marginTop:8 }}>
                    <span style={{ fontSize:11, color:"#aaa" }}>0ml</span>
                    <span style={{ fontSize:11, color:"#aaa" }}>2,000ml</span>
                  </div>
                </div>

                {pf.conditions?.map(c => {
                  const rule = ALERT_RULES[c];
                  if (rule && todayMeals.reduce((s,m) => s + (m[rule.key]||0), 0) > rule.limit)
                    return <div key={c} className="alert alert-warn">⚠️ {rule.msg}</div>;
                  return null;
                })}

                <div className="stat-grid">
                  <div className="stat-card"><div className="stat-num">{totals.kcal}</div><div className="stat-unit">kcal</div><div className="stat-lbl">오늘 섭취</div></div>
                  <div className="stat-card"><div className="stat-num">{totals.protein}g</div><div className="stat-lbl">단백질</div></div>
                  <div className="stat-card"><div className="stat-num" style={{ color: Math.round((totals.kcal/targetKcal)*100) >= 100 ? "#c0402a" : "#2d4a2a" }}>{Math.round((totals.kcal/targetKcal)*100)}%</div><div className="stat-lbl">목표 달성</div></div>
                </div>

                <div className="card">
                  <div style={{ fontWeight: 700, fontSize: 14, marginBottom: 12 }}>오늘의 영양 균형</div>
                  {[
                    { label: "칼로리", val: totals.kcal, max: targetKcal, color: "#3a6b34", unit: "kcal" },
                    { label: "단백질", val: totals.protein, max: pf.goal === "muscle" ? 80 : 60, color: "#4a7a7a", unit: "g" },
                    { label: "나트륨", val: totals.sodium, max: 2000, color: totals.sodium > 1800 ? "#c0402a" : "#8a6a30", unit: "mg" },
                  ].map(n => (
                    <div key={n.label} className="nut-row">
                      <span className="nut-label">{n.label}</span>
                      <div className="nut-track"><div className="nut-fill" style={{ width: Math.min(100,(n.val/n.max)*100) + "%", background: n.color }} /></div>
                      <span className="nut-val">{n.val}{n.unit}</span>
                    </div>
                  ))}
                </div>

                <div className="card">
                  <div style={{ fontWeight: 700, fontSize: 14, marginBottom: 12 }}>영양 성분 비율</div>
                  <div style={{ display: "flex", alignItems: "center" }}>
                    <div style={{ width: "45%", height: 140 }}>
                      <ResponsiveContainer width="100%" height="100%">
                        <PieChart><Pie data={pieData.filter(p => p.value > 0)} innerRadius={35} outerRadius={55} paddingAngle={4} dataKey="value" /></PieChart>
                      </ResponsiveContainer>
                    </div>
                    <div style={{ flex: 1, fontSize: 13 }}>
                      {pieData.map(p => (
                        <div key={p.name} style={{ display: "flex", alignItems: "center", gap: 6, marginBottom: 8 }}>
                          <div style={{ width: 10, height: 10, borderRadius: 2, background: p.fill, flexShrink: 0 }} />
                          <span style={{ color: "#666" }}>{p.name}</span>
                          <strong style={{ marginLeft: "auto" }}>{p.value}g</strong>
                        </div>
                      ))}
                      <div style={{ fontSize: 11, color: "#aaa", marginTop: 4 }}>나트륨 {totals.sodium}mg</div>
                    </div>
                  </div>
                </div>

                <div className="section-title">
                  오늘의 식사
                  <div style={{ display:"flex", gap:5 }}>
                    {favs.length > 0 && <button className="btn btn-outline btn-sm" style={{ padding:"5px 10px", fontSize:11 }} onClick={() => setShowFavs(true)}>★ 즐겨찾기</button>}
                    <button className="btn btn-outline btn-sm" style={{ padding:"5px 10px", fontSize:11 }} onClick={() => setShowAdd(true)}>+ 등록</button>
                    <button className="btn btn-outline btn-sm" style={{ padding:"5px 10px", fontSize:11 }} onClick={() => setView("analyze")}>📷</button>
                  </div>
                </div>
                <div className="card">
                  {todayMeals.length === 0
                    ? <div style={{ textAlign: "center", padding: "24px 0" }}>
                        <div style={{ fontSize: 28, marginBottom: 8 }}>🍽️</div>
