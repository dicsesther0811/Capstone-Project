      const toggle = (k, v) => setPf(p => ({ ...p, [k]: p[k].includes(v) ? p[k].filter(x => x !== v) : [...p[k], v] }));
      const next = () => {
        if (step === 0) { if (!pf.name.trim()) return setError("이름을 입력해주세요."); if (!pf.age || isNaN(pf.age)) return setError("나이를 올바르게 입력해주세요."); if (!pf.gender) return setError("성별을 선택해주세요."); }
        if (step === 1 && !pf.goal) return setError("목표를 선택해주세요.");
        setError(""); setStep(s => s + 1);
      };
      const finish = () => {
        const users = getUsers();
        const full = { ...pf, targetKcal: GOAL_KCAL[pf.goal] || 2000 };
        users[user.uid] = { ...users[user.uid], profile: full };
        saveUsers(users); saveMeals(user.uid, []);
        onComplete({ ...user, profile: full });
      };
      return (
        <div className="ob-wrap">
          <div className="ob-card">
            <div className="ob-step-bar">{["기본 정보","건강 목표","건강 상태"].map((_,i) => <div key={i} className={`ob-dot ${i < step ? "done" : i === step ? "active" : ""}`} />)}</div>
            {step === 0 && <>
              <div className="ob-title">안녕하세요! 👋</div>
              <div className="ob-desc">기본 정보를 입력해주세요.</div>
              <div className="form-group"><label className="form-label">이름 (닉네임)</label><input className="form-input" placeholder="홍길동" value={pf.name} onChange={e => set("name", e.target.value)} /></div>
              <div className="form-row">
                <div className="form-group"><label className="form-label">나이</label><input className="form-input" type="number" placeholder="25" value={pf.age} onChange={e => set("age", e.target.value)} /></div>
                <div className="form-group"><label className="form-label">성별</label><div className="chip-group">{["남성","여성","기타"].map(g => <button key={g} className={`chip ${pf.gender === g ? "selected" : ""}`} onClick={() => set("gender", g)}>{g}</button>)}</div></div>
              </div>
              <div className="form-row">
                <div className="form-group"><label className="form-label">키 (cm)</label><input className="form-input" type="number" placeholder="170" value={pf.height} onChange={e => set("height", e.target.value)} /></div>
                <div className="form-group"><label className="form-label">체중 (kg)</label><input className="form-input" type="number" placeholder="65" value={pf.weight} onChange={e => set("weight", e.target.value)} /></div>
              </div>
            </>}
            {step === 1 && <>
              <div className="ob-title">어떤 목표가 있으신가요?</div>
              <div className="ob-desc">목표에 따라 권장 칼로리와 영양 비율이 달라져요.</div>
              {[{val:"weight",label:"⚖️  체중 감량",desc:"칼로리 제한 · 고단백 · 목표 1,600 kcal"},{val:"muscle",label:"💪  근육 증가",desc:"고단백 · 충분한 탄수화물 · 목표 2,500 kcal"},{val:"health",label:"🌿  건강 유지",desc:"균형 잡힌 영양 관리 · 목표 2,000 kcal"},{val:"overseas",label:"🌍  해외 음식 적응",desc:"재료 정보 · 알레르기 확인 중심"}].map(g => (
                <button key={g.val} className={`goal-btn ${pf.goal === g.val ? "selected" : ""}`} onClick={() => set("goal", g.val)}>
                  <div className="goal-label">{g.label}</div><div className="goal-desc">{g.desc}</div>
                </button>
              ))}
            </>}
            {step === 2 && <>
              <div className="ob-title">건강 상태를 알려주세요</div>
              <div className="ob-desc">해당 항목을 선택하면 맞춤 식단이 제공돼요.</div>
              <div className="form-group"><label className="form-label">지병 / 건강 상태</label><div className="chip-group">{CONDITIONS.map(c => <button key={c} className={`chip ${pf.conditions.includes(c) ? "selected" : ""}`} onClick={() => toggle("conditions", c)}>{c}</button>)}</div></div>
              <div className="form-group"><label className="form-label">알레르기 (복수 선택)</label><div className="chip-group">{ALLERGIES.map(a => <button key={a} className={`chip ${pf.allergies.includes(a) ? "selected" : ""}`} onClick={() => toggle("allergies", a)}>{a}</button>)}</div></div>
            </>}
            {error && <div className="error-msg" style={{ marginTop: 8 }}>⚠ {error}</div>}
            <div className="btn-row">
              {step > 0 && <button className="btn-ghost" onClick={() => { setStep(s => s - 1); setError(""); }}>← 이전</button>}
              <button className="btn btn-primary" style={{ flex: 1 }} onClick={step < 2 ? next : finish}>{step < 2 ? "다음 →" : "🎉 시작하기"}</button>
            </div>
          </div>
        </div>
      );
    }

    /* ─── MAIN APP ─── */
    function App() {
      const [authState, setAuthState] = useState("loading");
      const [user, setUser] = useState(null);
      const [view, setView] = useState("dash");
      const [meals, setMeals] = useState([]);
      const [water, setWaterState] = useState(0);
      const [showAdd, setShowAdd] = useState(false);
      const [showProfile, setShowProfile] = useState(false);
      const [imgFile, setImgFile] = useState(null);
      const [imgPreview, setImgPreview] = useState(null);
      const [analyzeResult, setAnalyzeResult] = useState(null);
      const [analyzeLoading, setAnalyzeLoading] = useState(false);
      const [reco, setReco] = useState(null);
      const [recoLoading, setRecoLoading] = useState(false);
      const [favs, setFavs] = useState([]);
      const [reportPeriod, setReportPeriod] = useState("week");
      const [showFavs, setShowFavs] = useState(false);
      const fileRef = useRef();

      useEffect(() => {
        let s = getSession();
        if (!s) { try { s = JSON.parse(sessionStorage.getItem(SESSION_KEY) || "null"); } catch {} }
        if (s) {
          const u = getUsers()[s.uid];
          if (u) { setUser(u); setMeals(getMeals(u.uid)); setWaterState(getWater(u.uid)); setFavs(getFavs(u.uid)); setAuthState(u.profile ? "app" : "onboard"); }
          else setAuthState("auth");
        } else setAuthState("auth");
      }, []);

      const login = (u, remember = true) => {
        if (remember) { saveSession({ uid: u.uid, remember: true }); }
        else { try { sessionStorage.setItem(SESSION_KEY, JSON.stringify({ uid: u.uid })); } catch {} }
        setUser(u); setMeals(getMeals(u.uid)); setWaterState(getWater(u.uid)); setFavs(getFavs(u.uid)); setAuthState(u.profile ? "app" : "onboard");
      };
      const signup = u => { saveSession({ uid: u.uid, remember: true }); setUser(u); setAuthState("onboard"); };
      const onboardDone = u => { setUser(u); setMeals(getMeals(u.uid)); setWaterState(getWater(u.uid)); setFavs(getFavs(u.uid)); setAuthState("app"); };
      const logout = () => { clearSession(); setUser(null); setMeals([]); setAuthState("auth"); setView("dash"); };
      const handleProfileSave = updated => {
        const users = getUsers();
        const updatedUser = { ...user, profile: updated };
        users[user.uid] = updatedUser; saveUsers(users); setUser(updatedUser);
      };
      const setWater = v => { setWaterState(v); if (user) saveWater(user.uid, v); };
      const addMeal = m => { const updated = [m, ...meals]; setMeals(updated); if (user) saveMeals(user.uid, updated); };
      const deleteMeal = id => { const updated = meals.filter(x => x.id !== id); setMeals(updated); if (user) saveMeals(user.uid, updated); };
      const toggleFav = (meal) => {
        const exists = favs.find(f => f.name === meal.name);
        const updated = exists ? favs.filter(f => f.name !== meal.name) : [{ name: meal.name, emoji: meal.emoji || "🍽️", kcal: meal.kcal, protein: meal.protein, carbs: meal.carbs, fat: meal.fat, sodium: meal.sodium, ingredients: meal.ingredients || [] }, ...favs];
        setFavs(updated); if (user) saveFavs(user.uid, updated);
      };
      const addFavMeal = (fav) => {
        addMeal({ ...fav, id: Date.now(), time: new Date().toTimeString().slice(0,5), date: TODAY, isEstimated: false });
        setShowFavs(false);
      };

      const pf = user?.profile || {};
      const targetKcal = pf.targetKcal || 2000;
      const todayMeals = meals.filter(m => m.date === TODAY);
      const totals = todayMeals.reduce((a, m) => ({ kcal: a.kcal+m.kcal, protein: a.protein+m.protein, carbs: a.carbs+m.carbs, fat: a.fat+m.fat, sodium: a.sodium+m.sodium }), { kcal:0, protein:0, carbs:0, fat:0, sodium:0 });
      const kcalPct = Math.min(100, Math.round((totals.kcal / targetKcal) * 100));
      const initials = pf.name?.[0]?.toUpperCase() || "U";

      const weekData = [...Array(7)].map((_, i) => {
        const d = new Date(); d.setDate(d.getDate() - (6 - i));
        const dayMeals = meals.filter(m => m.date === d.toDateString());
        return { name: ["일","월","화","수","목","금","토"][d.getDay()], kcal: dayMeals.reduce((s,m) => s+m.kcal, 0) };
      });
      const pieData = [
        { name: "탄수화물", value: totals.carbs, fill: "#8884d8" },
        { name: "단백질", value: totals.protein, fill: "#82ca9d" },
        { name: "지방", value: totals.fat, fill: "#ffc658" },
      ];

      const handleFile = f => {
        if (!f) return; setImgFile(f); setAnalyzeResult(null);
        const r = new FileReader(); r.onload = e => setImgPreview(e.target.result); r.readAsDataURL(f);
      };
      const analyze = async () => {
        if (!imgFile) return; setAnalyzeLoading(true);
        try {
          const base64 = imgPreview.split(",")[1];
          const allergyNote = pf.allergies?.length ? "사용자 알레르기: " + pf.allergies.join(", ") : "";
          const res = await fetch("https://api.anthropic.com/v1/messages", {
            method: "POST", headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ model: "claude-sonnet-4-5-20251016", max_tokens: 1000,
              messages: [{ role: "user", content: [
                { type: "image", source: { type: "base64", media_type: imgFile.type || "image/jpeg", data: base64 } },
                { type: "text", text: '이 음식을 분석해서 JSON만 출력해. ' + allergyNote + '\n{"name":"음식명","ingredients":["재료"],"calories":숫자,"protein":숫자,"carbs":숫자,"fat":숫자,"sodium":숫자,"healthScore":숫자,"allergyWarning":null또는"경고문구","comment":"코멘트"}' }
              ]}]
            })
          });
          if (!res.ok) throw new Error("API " + res.status);
          const data = await res.json();
          const raw = data.content?.[0]?.text || "";
          const s = raw.indexOf("{"), e2 = raw.lastIndexOf("}");
          setAnalyzeResult(s !== -1 && e2 !== -1 ? JSON.parse(raw.slice(s, e2+1)) : null);
        } catch { setAnalyzeResult({ name: "분석 실패", ingredients: [], calories: 0, protein: 0, carbs: 0, fat: 0, sodium: 0, healthScore: 0, comment: "이미지를 다시 시도해주세요." }); }
        setAnalyzeLoading(false);
      };
      const saveAnalysis = () => {
        if (!analyzeResult) return;
        addMeal({ id: Date.now(), name: analyzeResult.name, emoji: "🍽️", time: new Date().toTimeString().slice(0,5), date: TODAY,
          kcal: analyzeResult.calories, protein: analyzeResult.protein, carbs: analyzeResult.carbs, fat: analyzeResult.fat, sodium: analyzeResult.sodium, ingredients: analyzeResult.ingredients });
        setImgPreview(null); setImgFile(null); setAnalyzeResult(null); setView("dash");
      };

      const getRecommendations = async () => {
        setRecoLoading(true); setReco(null);
        try {
          const summary = todayMeals.length ? todayMeals.map(m => m.name + "(" + m.kcal + "kcal)").join(", ") : "없음";
          const cond = pf.conditions?.length ? pf.conditions.join(",") : "없음";
          const goal = GOAL_MAP[pf.goal] || "건강유지";
          const condGuide = pf.conditions?.includes("당뇨") ? "당뇨:현미밥,두부,채소,생선권장/흰밥,설탕,정제탄수화물금지" :
            pf.conditions?.includes("고혈압") ? "고혈압:나트륨2000mg이하,칼륨풍부채소권장/짠음식금지" :
            pf.conditions?.includes("고지혈증") ? "고지혈증:등푸른생선,견과류,채소권장/포화지방,튀김금지" : "";
          const prompt = "영양사로서 JSON만 출력해. 사용자:" + (pf.age||"?") + "세 " + goal
            + (cond !== "없음" ? " 지병:" + cond : "")
            + (pf.allergies?.length ? " 알레르기:" + pf.allergies.join(",") : "")
            + " 오늘:" + summary + " " + totals.kcal + "kcal/목표" + targetKcal + "kcal"
            + (condGuide ? " 지침:" + condGuide : "")
            + '\n{"analysis":"2문장","recommendations":[{"food":"음식명","reason":"짧은이유","nutrients":"영양소","emoji":"이모지"},{"food":"","reason":"","nutrients":"","emoji":""},{"food":"","reason":"","nutrients":"","emoji":""}],"avoidFoods":["음식1","음식2"],"tips":["팁1"],"warnings":["주의"]}';
          const res = await fetch("https://api.anthropic.com/v1/messages", {
            method: "POST", headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ model: "claude-haiku-4-5-20251001", max_tokens: 800, messages: [{ role: "user", content: prompt }] })
          });
          if (!res.ok) throw new Error("API " + res.status);
          const data = await res.json();
          if (data.error) throw new Error(data.error.message);
          const raw = data.content?.[0]?.text || "";
          const s = raw.indexOf("{"), e2 = raw.lastIndexOf("}");
          if (s === -1 || e2 === -1) throw new Error("응답 형식 오류");
          setReco(JSON.parse(raw.slice(s, e2+1)));
        } catch (e) { setReco({ analysis: "오류: " + e.message, recommendations: [], avoidFoods: [], tips: [], warnings: [] }); }
        setRecoLoading(false);
      };

      if (authState === "loading") return <div style={{ minHeight:"100vh", display:"flex", alignItems:"center", justifyContent:"center", background:"#1c2b1e" }}><div className="spinner" /></div>;
      if (authState === "auth") return <AuthScreen onLogin={login} onSignup={signup} />;
      if (authState === "onboard") return <Onboarding user={user} onComplete={onboardDone} />;

      return (
        <>
          {showProfile && <ProfileModal user={user} pf={pf} initials={initials} onClose={() => setShowProfile(false)} onSave={handleProfileSave} />}
          {showAdd && <ManualMealModal onClose={() => setShowAdd(false)} onSave={m => addMeal(m)} />}

          <div className="screen">
            <header className="header">
              <div className="logo">Food<span>Lens</span></div>
