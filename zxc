                    <div style={{ fontWeight: 700, fontSize: 15, color: "#1c2b1e", marginBottom: 3 }}>{estimated.emoji} {estimated.name}</div>
                    <div style={{ fontSize: 12, color: "#7a9076" }}>"{foodText.trim()}"으로 입력하셨어요</div>
                  </div>
                  <div style={{ display: "grid", gridTemplateColumns: "repeat(3,1fr)", gap: 8, marginBottom: 14 }}>
                    {[
                      { label: "칼로리", val: estimated.kcal, unit: "kcal", color: "#3a6b34" },
                      { label: "단백질", val: estimated.protein, unit: "g", color: "#4a7a7a" },
                      { label: "탄수화물", val: estimated.carbs, unit: "g", color: "#8a6a30" },
                      { label: "지방", val: estimated.fat, unit: "g", color: "#7a5a8a" },
                      { label: "나트륨", val: estimated.sodium, unit: "mg", color: estimated.sodium > 800 ? "#c0402a" : "#3a6b34" },
                    ].map(n => (
                      <div key={n.label} style={{ background: "#fff", border: "1px solid #eee", borderRadius: 10, padding: "10px 8px", textAlign: "center" }}>
                        <div style={{ fontSize: 11, color: "#7a9076", marginBottom: 2 }}>{n.label}</div>
                        <div style={{ fontSize: 15, fontWeight: 700, color: n.color }}>{n.val}</div>
                        <div style={{ fontSize: 10, color: "#9ab096" }}>{n.unit}</div>
                      </div>
                    ))}
                  </div>
                  {(estimated.ingredients || []).length > 0 && (
                    <div style={{ marginBottom: 10 }}>
                      <div style={{ fontSize: 11, color: "#7a9076", fontWeight: 700, textTransform: "uppercase", letterSpacing: "0.4px", marginBottom: 5 }}>추정 재료</div>
                      {estimated.ingredients.map((ing, i) => <span key={i} className="tag tag-green">{ing}</span>)}
                    </div>
                  )}
                  {estimated.note && <div className="alert alert-ok"><span>💬</span><span style={{ fontSize: 12 }}>{estimated.note}</span></div>}
                  <div style={{ fontSize: 11, color: "#b0b8ad", marginTop: 8, textAlign: "center" }}>※ AI 추정값으로 실제 수치와 차이가 있을 수 있어요</div>
                </>
              )}
            </div>
            <div className="modal-footer">
              {step === "input" && <><button className="btn btn-ghost btn-sm" onClick={onClose}>취소</button><button className="btn btn-primary btn-sm" style={{ flex: 1 }} onClick={estimate}>AI로 칼로리 추정하기 →</button></>}
              {step === "confirm" && <><button className="btn btn-outline btn-sm" onClick={() => { setStep("input"); setEstimated(null); }}>다시 입력</button><button className="btn btn-primary btn-sm" style={{ flex: 1 }} onClick={handleSave}>이대로 등록</button></>}
            </div>
          </div>
        </div>
      );
    }

