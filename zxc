    /* ─── MANUAL MEAL MODAL ─── */
    function ManualMealModal({ onClose, onSave }) {
      const now = new Date();
      const [step, setStep] = useState("input");
      const [foodText, setFoodText] = useState("");
      const [time, setTime] = useState(String(now.getHours()).padStart(2,"0") + ":" + String(now.getMinutes()).padStart(2,"0"));
      const [estimated, setEstimated] = useState(null);
      const [error, setError] = useState("");

      const estimate = async () => {
        if (!foodText.trim()) return setError("먹은 음식을 입력해주세요.");
        setError(""); setStep("estimating");
        try {
          const prompt = "다음 식사의 영양 정보를 추정해서 JSON만 출력해. 다른 텍스트 없이 JSON만. 식사: " + foodText.trim()
            + ' {"name":"대표 음식명","emoji":"음식 이모지 1개","kcal":숫자,"protein":숫자,"carbs":숫자,"fat":숫자,"sodium":숫자,"ingredients":["재료1","재료2"],"note":"추정 근거 한 줄"}';
          const res = await fetch("https://api.anthropic.com/v1/messages", {
            method: "POST", headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ model: "claude-haiku-4-5-20251001", max_tokens: 400, messages: [{ role: "user", content: prompt }] })
          });
          if (!res.ok) throw new Error("API " + res.status);
          const data = await res.json();
          const raw = data.content?.[0]?.text || "";
          const s = raw.indexOf("{"), e2 = raw.lastIndexOf("}");
          if (s === -1 || e2 === -1) throw new Error("파싱 실패");
          setEstimated(JSON.parse(raw.slice(s, e2 + 1)));
          setStep("confirm");
        } catch (e) { setError("추정 실패: " + e.message); setStep("input"); }
      };

      const handleSave = () => {
        if (!estimated) return;
        onSave({ id: Date.now(), name: estimated.name || foodText.trim(), emoji: estimated.emoji || "🍽️", time, date: TODAY,
          kcal: Number(estimated.kcal)||0, protein: Number(estimated.protein)||0, carbs: Number(estimated.carbs)||0,
          fat: Number(estimated.fat)||0, sodium: Number(estimated.sodium)||0, ingredients: estimated.ingredients||[], isEstimated: true });
        onClose();
      };

      return (
        <div className="modal-overlay" onClick={onClose}>
          <div className="modal" style={{ maxWidth: 440 }} onClick={e => e.stopPropagation()}>
            <div className="modal-header">
              <div className="modal-av" style={{ fontSize: 22 }}>{step === "confirm" && estimated ? estimated.emoji : "✏️"}</div>
